{
  "name": "deslop-cli",
  "version": "0.0.16",
  "description": "CLI for deslop-js — find unused files, exports, and dependencies",
  "keywords": [
    "cli",
    "dead-code",
    "dependencies",
    "exports",
    "javascript",
    "typescript",
    "unused"
  ],
  "homepage": "https://github.com/millionco/deslop-js#readme",
  "bugs": {
    "url": "https://github.com/millionco/deslop-js/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Aiden Bai",
    "email": "aiden@million.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/millionco/deslop-js.git",
    "directory": "packages/deslop-cli"
  },
  "bin": {
    "deslop": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "deslop-js": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
