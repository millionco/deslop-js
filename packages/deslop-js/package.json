{
  "name": "deslop-js",
  "version": "0.0.1",
  "description": "Deslop JavaScript code",
  "keywords": [
    "dead-code",
    "unused",
    "exports",
    "files",
    "dependencies",
    "typescript",
    "javascript",
    "oxc"
  ],
  "license": "MIT",
  "author": {
    "name": "Aiden Bai",
    "email": "aiden@million.dev"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@oxc-project/types": "^0.130.0",
    "fast-glob": "^3.3.3",
    "minimatch": "^10.2.5",
    "oxc-parser": "^0.130.0",
    "oxc-resolver": "^11.19.1"
  },
  "devDependencies": {
    "@types/minimatch": "^5.1.2",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0"
  }
}
